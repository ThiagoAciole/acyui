{
  "name": "acioleui",
  "version": "0.1.0",
  "description": "AcioleUI React component library",
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": {
      "types": "./dist/acioleui.css.d.ts",
      "default": "./dist/acioleui.css"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.es.js",
      "require": "./dist/icons.cjs.js"
    },
    "./dist/acioleui.css": "./dist/acioleui.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "generate:icons": "node ./scripts/generate-icons.mjs",
    "build": "npm run generate:icons && vite build",
    "dev": "npm run generate:icons && vite build --watch",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.27.3",
    "lucide": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.59.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-svgr": "^4.5.0"
  }
}
